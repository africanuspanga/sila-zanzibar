# SILA — environment variables
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored; never commit real credentials.

# --- Supabase ---------------------------------------------------------------
# Project URL and anon (public) key — used by the site for content reads and
# RLS-guarded form submissions. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key — SERVER ONLY. Bypasses Row Level Security. Used by the seed
# script (`npm run db:seed`) and privileged server work. NEVER expose this or
# prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Until these are set, the site automatically falls back to the placeholder
# content in lib/data.ts, so it keeps working with no configuration.

# --- Admin dashboard (/admin) -----------------------------------------------
# The admin signs in through Supabase Auth. ADMIN_EMAIL is the only account
# allowed into /admin (defaults to admin@silazanzibar.com if omitted).
ADMIN_EMAIL=admin@silazanzibar.com

# Used ONLY by `npm run admin:create` to create/reset the admin's Supabase Auth
# password. Not read by the running app. Keep it in .env.local (gitignored) —
# never commit it. After creating the user you can delete this line.
ADMIN_PASSWORD=set-a-strong-password

# --- Supabase CLI (migrations) ----------------------------------------------
# Personal access token for `supabase login` (non-interactive). Create one at
# https://supabase.com/dashboard/account/tokens . Only needed locally/CI to run
# `supabase db push` — NOT required by the deployed app.
# SUPABASE_ACCESS_TOKEN=sbp_xxx
